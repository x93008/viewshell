{
    "version": 4,
    "vendor": {
        "conan": {}
    },
    "include": [
        ".conan/build/Debug/generators/CMakePresets.json"
    ],
    "configurePresets": [
        {
            "name": "debug",
            "displayName": "Debug build with conan deps",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "toolchainFile": "${sourceDir}/.conan/build/Debug/generators/conan_toolchain.cmake",
            "inherits": ["conan-debug"]
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "configurePreset": "debug",
            "jobs": 16
        }
    ],
    "testPresets": [
        {
            "name": "debug",
            "configurePreset": "debug",
            "execution": {
                "jobs": 16
            }
        }
    ]
}
